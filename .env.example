# === Server ===
PORT=3001
NODE_ENV=development

# === AI ===
CLAUDE_API_KEY=sk-ant-api03-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# === Git (Primary: Game Data) ===
GITLAB_REPO_URL=http://your-gitlab-host/project/data.git
GITLAB_TOKEN=glpat-your-token-here

# === Git (Secondary: Game Code) ===
GITLAB_REPO2_URL=http://your-gitlab-host/project/code.git
GITLAB_REPO2_TOKEN=glpat-your-token-here

# === Git Paths ===
GIT_CLONE_BASE_DIR=./data/repos
REPO_SCHEMA_SUBPATH=
REPO_DATA_SUBPATH=
AUTO_SYNC_ON_START=true

# === Jira ===
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_USER_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_DEFAULT_PROJECT=YOUR_PROJECT

# === Confluence ===
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net

# === Google Sheets (StringData / Localization) ===
# Spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEETS_ID=your-spreadsheet-id
# API Key (시트가 "링크가 있는 모든 사용자"에게 공유된 경우)
GOOGLE_API_KEY=your-google-api-key
# (선택) Service Account JSON — API Key 없이 비공개 시트 접근 시
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
# Sync interval in ms (default 5 min = 300000)
GOOGLE_STRINGDATA_SYNC_INTERVAL=300000

# === Slack ===
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token

# === Storage ===
DB_PATH=./data/datamaster.db
WIKI_DIR=./data/wiki
